@page "/modal-dialog"
<h3>ModalDialog Component</h3>
<p>A modal dialog component built on the native HTML &lt;dialog&gt; element. It provides a clean overlay with header, body, and footer sections, supporting customizable buttons and events.</p>

<div class="d-flex align-items-center component-container">
    <div class="p-2 interactivity-card">
        <h5>Parameters</h5>
        <table class="table table-sm mb-0">
            <tbody>
                <tr>
                    <td><label for="option_title" style="margin-right: 5px;">Title</label></td>
                    <td><input type="text" id="option_title" style="width: 150px;" @bind-value=_title></td>
                </tr>
                <tr>
                    <td><label for="option_summary" style="margin-right: 5px;">Summary</label></td>
                    <td><input type="text" id="option_summary" style="width: 150px;" @bind-value=_summary></td>
                </tr>
                <tr>
                    <td><label for="option_size" style="margin-right: 5px;">Size</label></td>
                    <td>
                        <select id="option_size" @bind-value=_size @bind-value:event="onchange">
                            <option value=@Size.ExtraSmall>Extra Small</option>
                            <option value=@Size.Small>Small</option>
                            <option value=@Size.Medium selected>Medium</option>
                            <option value=@Size.Large>Large</option>
                            <option value=@Size.ExtraLarge>Extra Large</option>
                        </select>
                    </td>
                </tr>
                <tr>
                    <td><label for="option_submit_text" style="margin-right: 5px;">Submit Text</label></td>
                    <td><input type="text" id="option_submit_text" style="width: 150px;" @bind-value=_submitText></td>
                </tr>
                <tr>
                    <td><label for="option_cancel_text" style="margin-right: 5px;">Cancel Text</label></td>
                    <td><input type="text" id="option_cancel_text" style="width: 150px;" @bind-value=_cancelText></td>
                </tr>
                <tr>
                    <td><label for="option_show_close" style="margin-right: 5px;">Show Close Button</label></td>
                    <td><ToggleSwitch id="option_show_close" @bind-Checked=_showCloseButton /></td>
                </tr>
                <tr>
                    <td><label for="option_show_submit" style="margin-right: 5px;">Show Submit Button</label></td>
                    <td><ToggleSwitch id="option_show_submit" @bind-Checked=_showSubmitButton /></td>
                </tr>
                <tr>
                    <td><label for="option_show_cancel" style="margin-right: 5px;">Show Cancel Button</label></td>
                    <td><ToggleSwitch id="option_show_cancel" @bind-Checked=_showCancelButton /></td>
                </tr>
            </tbody>
        </table>
        <div class="mt-3">
            <button class="btn btn-primary" @onclick="ShowInteractiveDialog">Open Dialog</button>
        </div>
    </div>
    <div class="p-2 flex-grow-1 justify-content-center">
        <div class="px-0 px-md-5 text-center">
            <p><strong>Last Action:</strong> @_lastAction</p>
        </div>
    </div>
</div>

<ModalDialog @ref=_interactiveDialog
             Title=@_title
             Summary=@_summary
             Size=@_size
             SubmitButtonText=@_submitText
             CancelButtonText=@_cancelText
             ShowCloseButton=@_showCloseButton
             ShowSubmitButton=@_showSubmitButton
             ShowCancelButton=@_showCancelButton
             OnClose="HandleClose"
             OnSubmit="HandleSubmit">
    <p>This is the modal content. You can put any Blazor content here.</p>
</ModalDialog>

<hr />

<h4>Basic Modal Dialog</h4>
<p>A simple modal dialog with title and content.</p>
<pre><code>&lt;ModalDialog @@ref="_basicDialog" Title="Basic Dialog" OnClose="HandleClose" OnSubmit="HandleSubmit"&gt;
    &lt;p&gt;This is a basic modal dialog.&lt;/p&gt;
&lt;/ModalDialog&gt;

&lt;button @@onclick="() => _basicDialog.ShowAsync()"&gt;Open Basic Dialog&lt;/button&gt;</code></pre>

<button class="btn btn-secondary mb-3" @onclick="() => _basicDialog.ShowAsync()">Open Basic Dialog</button>

<ModalDialog @ref=_basicDialog Title="Basic Dialog" OnClose="HandleBasicClose" OnSubmit="HandleBasicSubmit">
    <p>This is a basic modal dialog with default settings.</p>
</ModalDialog>

<hr />

<h4>Confirmation Dialog</h4>
<p>A confirmation dialog with custom button text, useful for delete or destructive actions.</p>
<pre><code>&lt;ModalDialog @@ref="_confirmDialog" 
             Title="Confirm Delete" 
             Summary="This action cannot be undone."
             SubmitButtonText="Delete"
             CancelButtonText="Keep"
             Size="Size.Small"&gt;
    &lt;p&gt;Are you sure you want to delete this item?&lt;/p&gt;
&lt;/ModalDialog&gt;</code></pre>

<button class="btn btn-danger mb-3" @onclick="() => _confirmDialog.ShowAsync()">Delete Item</button>

<ModalDialog @ref=_confirmDialog 
             Title="Confirm Delete" 
             Summary="This action cannot be undone."
             SubmitButtonText="Delete"
             CancelButtonText="Keep"
             Size="Size.Small"
             OnClose="HandleConfirmClose"
             OnSubmit="HandleConfirmSubmit">
    <p>Are you sure you want to delete this item?</p>
</ModalDialog>

<hr />

<h4>Information Dialog (No Footer Buttons)</h4>
<p>A dialog with only a close button, useful for displaying information.</p>
<pre><code>&lt;ModalDialog @@ref="_infoDialog" 
             Title="Information" 
             ShowSubmitButton="false"
             ShowCancelButton="false"&gt;
    &lt;p&gt;This is an informational message.&lt;/p&gt;
&lt;/ModalDialog&gt;</code></pre>

<button class="btn btn-info mb-3" @onclick="() => _infoDialog.ShowAsync()">Show Info</button>

<ModalDialog @ref=_infoDialog 
             Title="Information" 
             ShowSubmitButton="false"
             ShowCancelButton="false"
             OnClose="HandleInfoClose">
    <p>This is an informational message. Click the X button or press Escape to close.</p>
</ModalDialog>

<hr />

<h4>Large Dialog with Rich Content</h4>
<p>A larger dialog demonstrating rich content support.</p>

<button class="btn btn-success mb-3" @onclick="() => _largeDialog.ShowAsync()">Open Large Dialog</button>

<ModalDialog @ref=_largeDialog 
             Title="Terms and Conditions" 
             Summary="Please review the following terms."
             Size="Size.Large"
             SubmitButtonText="I Agree"
             CancelButtonText="Decline"
             OnClose="HandleLargeClose"
             OnSubmit="HandleLargeSubmit">
    <div style="max-height: 300px; overflow-y: auto;">
        <h5>1. Introduction</h5>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nullam euismod, nisi vel consectetur interdum, nisl nunc egestas nunc, vitae tincidunt nisl nunc euismod nunc.</p>
        <h5>2. Terms of Use</h5>
        <p>Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
        <h5>3. Privacy Policy</h5>
        <p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.</p>
        <h5>4. Disclaimers</h5>
        <p>Sunt in culpa qui officia deserunt mollit anim id est laborum. Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
    </div>
</ModalDialog>
